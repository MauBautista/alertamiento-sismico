# TAKAB · Variables de entorno de desarrollo local
# Copia este archivo a .env (git lo ignora) y ajusta si hace falta.
# NUNCA pongas credenciales reales aquí: este archivo SÍ se versiona.

# --- PostgreSQL local (docker-compose.yml) ---
# 5433: el 5432 del host suele estar ocupado; 5433 es el default de la app.
POSTGRES_USER=takab
POSTGRES_PASSWORD=takab_dev
POSTGRES_DB=takab
POSTGRES_PORT=5433

# --- API (api/) ---
# Default de la app (api/src/takab_api/settings.py); expórtala para pytest/
# alembic si tu DB no está en 5433. El stack usa psycopg3 (sync y async).
# DATABASE_URL=postgresql+psycopg://takab:takab_dev@127.0.0.1:5433/takab

# --- Command service + config sync (T-1.23) ---
# Clave HMAC compartida con el edge (TAKAB_EDGE_HMAC_KEY). Vacía = fail-closed:
# POST /sites/{id}/commands responde 503 y el config sync no publica.
# TAKAB_API_COMMAND_HMAC_KEY=
# TAKAB_API_COMMAND_TTL_S=30
# TAKAB_API_COMMAND_RATE_USER_SITE_PER_MIN=6
# TAKAB_API_COMMAND_RATE_SITE_PER_MIN=12

# --- Backfill por S3 (T-1.25) ---
# TTL corto del presigned PUT (anti-thundering-herd).
# TAKAB_API_BACKFILL_PRESIGN_TTL_S=900

# --- Billing/metering (T-1.24) ---
# Bytes promedio por fila para gb_approx (calibrar con pg_column_size real).
# TAKAB_API_BILLING_ROW_BYTES_ESTIMATE=150

# --- Notificaciones (T-1.21) ---
# Vacío = provider de email simulado; con valor = SES (sandbox en dev).
# TAKAB_API_NOTIFY_EMAIL_FROM=

# --- Web (web/) ---
# VITE_API_BASE_URL=http://localhost:8000
