{
  "description": "Paquete de muestras de un canal (miniSEED decodificado).",
  "properties": {
    "network": {
      "default": "AM",
      "title": "Network",
      "type": "string"
    },
    "station": {
      "title": "Station",
      "type": "string"
    },
    "location": {
      "default": "",
      "title": "Location",
      "type": "string"
    },
    "channel": {
      "title": "Channel",
      "type": "string"
    },
    "starttime": {
      "format": "date-time",
      "title": "Starttime",
      "type": "string"
    },
    "sample_rate": {
      "default": 100.0,
      "title": "Sample Rate",
      "type": "number"
    },
    "samples": {
      "items": {
        "type": "integer"
      },
      "title": "Samples",
      "type": "array"
    }
  },
  "required": [
    "station",
    "channel",
    "starttime",
    "samples"
  ],
  "title": "WaveformPacket",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://takab.mx/schemas/waveform_packet/v1.2.0",
  "version": "1.2.0"
}
