# TAKAB Consola SOC · variables de entorno (Vite)
# Copia este archivo a web/.env (git lo ignora) y llena los huecos.
# NUNCA valores reales aquí: este archivo SÍ se versiona.
# Los valores del pool/cliente salen de: terraform -chdir=infra/terraform/envs/dev output

# Base del API. En dev se deja "/api": el proxy de Vite reenvía a :8000 (la API
# no monta CORS y el prefijo evita la colisión de paths SPA/API como /fleet).
VITE_API_BASE_URL=/api

# Cognito (takab-docs/specs/cognito-pool-v1.md). authority = issuer del pool.
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-2.amazonaws.com/<USER_POOL_ID>
VITE_COGNITO_CLIENT_ID=<SPA_CLIENT_ID>
VITE_COGNITO_DOMAIN=https://<HOSTED_UI_DOMAIN>.auth.us-east-2.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_COGNITO_POST_LOGOUT_URI=http://localhost:5173/
# VITE_COGNITO_SCOPES=openid email profile

# Panel de login local sin Cognito vía POST /dev/token (la API debe correr con
# JWKS inline — nunca disponible en producción).
VITE_DEV_TOKEN_ENABLED=true
